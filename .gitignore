# ------------------------------------------------------------
# Databases
# Keep the small ecommerce.db for Streamlit Cloud deployment,
# but ignore scratch / temp databases.
# ------------------------------------------------------------
*.sqlite
*.sqlite3
data/database/*.log

# ------------------------------------------------------------
# Project data files
# Raw Kaggle CSV is large (~25MB) - keep gitignored; provide a
# download script instead. Processed outputs are regenerated
# by the ETL, so we ignore them too.
# ------------------------------------------------------------
data/raw/orders.csv
data/raw/e-commerce.csv
data/processed/*.csv
reports/weekly_report_*.xlsx

# ------------------------------------------------------------
# Logs / quality reports generated by the pipeline
# ------------------------------------------------------------
*.log
logs/
quality_report.json
etl_run_*.json

# ------------------------------------------------------------
# OS / misc
# ------------------------------------------------------------
nul
EOF
