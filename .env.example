# ============================================================
# Environment variables template
# Copy this file to ".env" and fill in real values.
#   cp .env.example .env   (macOS/Linux)
#   copy .env.example .env (Windows)
#
# IMPORTANT: Never commit your real .env file. It is gitignored.
# ============================================================

# ----- PostgreSQL (local development) -----
# Create the DB first:  CREATE DATABASE ecommerce;
PG_HOST=localhost
PG_PORT=5432
PG_NAME=ecommerce
PG_USER=postgres
PG_PASSWORD=changeme

# ----- SQLite (used by Streamlit Cloud deployment) -----
# Relative path from the project root.
SQLITE_PATH=data/database/ecommerce.db

# ----- Kaggle dataset download (optional) -----
# Only needed if you run scripts/download_kaggle_dataset.py
# KAGGLE_USERNAME=your_kaggle_username
# KAGGLE_KEY=your_kaggle_api_key

# ----- Streamlit -----
# Set to "true" when deploying to Streamlit Cloud
STREAMLIT_ENV=local
